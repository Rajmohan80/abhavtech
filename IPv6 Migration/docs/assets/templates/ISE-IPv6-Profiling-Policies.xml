<?xml version="1.0" encoding="UTF-8"?>
<!-- 
ABHAVTECH ISE IPv6 PROFILING POLICIES
Import into ISE via: Administration > System > Maintenance > Import/Export > Import
Version: 1.0
-->
<ProfilingPolicyExport>
  <ProfilingPolicy name="Windows-Workstation-IPv6" description="Windows workstation detected via DHCPv6 fingerprint">
    <ParentPolicy>Workstation</ParentPolicy>
    <Rules>
      <Rule>
        <RuleType>AND</RuleType>
        <Conditions>
          <Condition>
            <AttributeName>DHCP-Option(55)</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>1,15,3,6,44,46</Value>
            <Description>DHCPv4 parameter request list (Windows signature)</Description>
          </Condition>
          <Condition>
            <AttributeName>DHCPv6-Option(1)</AttributeName>
            <Operator>EXISTS</Operator>
            <Value></Value>
            <Description>DHCPv6 Client Identifier (DUID) present</Description>
          </Condition>
          <Condition>
            <AttributeName>DHCPv6-Vendor-Class</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>MSFT 5.0</Value>
            <Description>Microsoft DHCPv6 vendor class</Description>
          </Condition>
        </Conditions>
      </Rule>
    </Rules>
    <Actions>
      <AssignSGT>10</AssignSGT>
      <AssignProfile>Microsoft-Workstation</AssignProfile>
    </Actions>
    <Priority>100</Priority>
    <Enabled>true</Enabled>
  </ProfilingPolicy>

  <ProfilingPolicy name="iPhone-iOS-IPv6" description="Apple iPhone detected via DHCPv6 vendor class">
    <ParentPolicy>Apple-Device</ParentPolicy>
    <Rules>
      <Rule>
        <RuleType>AND</RuleType>
        <Conditions>
          <Condition>
            <AttributeName>DHCPv6-Vendor-Class</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>Apple</Value>
            <Description>Apple DHCPv6 vendor identifier</Description>
          </Condition>
          <Condition>
            <AttributeName>User-Agent</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>iPhone</Value>
            <Description>HTTP User-Agent contains iPhone</Description>
          </Condition>
          <Condition>
            <AttributeName>OUI</AttributeName>
            <Operator>STARTS_WITH</Operator>
            <Value>00:03:93,00:05:02,00:0A:27,00:0D:93</Value>
            <Description>Apple OUI ranges</Description>
          </Condition>
        </Conditions>
      </Rule>
    </Rules>
    <Actions>
      <AssignSGT>10</AssignSGT>
      <AssignProfile>Apple-iPhone</AssignProfile>
    </Actions>
    <Priority>100</Priority>
    <Enabled>true</Enabled>
  </ProfilingPolicy>

  <ProfilingPolicy name="Android-Device-IPv6" description="Android device detected via DHCPv6">
    <ParentPolicy>Android</ParentPolicy>
    <Rules>
      <Rule>
        <RuleType>AND</RuleType>
        <Conditions>
          <Condition>
            <AttributeName>DHCPv6-Vendor-Class</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>dhcpcd</Value>
            <Description>Android DHCPv6 client (dhcpcd)</Description>
          </Condition>
          <Condition>
            <AttributeName>User-Agent</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>Android</Value>
            <Description>HTTP User-Agent contains Android</Description>
          </Condition>
        </Conditions>
      </Rule>
    </Rules>
    <Actions>
      <AssignSGT>10</AssignSGT>
      <AssignProfile>Android-Device</AssignProfile>
    </Actions>
    <Priority>100</Priority>
    <Enabled>true</Enabled>
  </ProfilingPolicy>

  <ProfilingPolicy name="IoT-Camera-IPv6" description="IP Camera using DHCPv6 stateful">
    <ParentPolicy>Camera</ParentPolicy>
    <Rules>
      <Rule>
        <RuleType>AND</RuleType>
        <Conditions>
          <Condition>
            <AttributeName>DHCPv6-Option(1)</AttributeName>
            <Operator>EXISTS</Operator>
            <Value></Value>
            <Description>DHCPv6 DUID present (stateful addressing)</Description>
          </Condition>
          <Condition>
            <AttributeName>OUI</AttributeName>
            <Operator>STARTS_WITH</Operator>
            <Value>00:40:8C,AC:CC:8E</Value>
            <Description>Axis Communications OUI</Description>
          </Condition>
          <Condition>
            <AttributeName>HTTP-User-Agent</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>AXIS</Value>
            <Description>Axis camera HTTP signature</Description>
          </Condition>
        </Conditions>
      </Rule>
    </Rules>
    <Actions>
      <AssignSGT>25</AssignSGT>
      <AssignProfile>Axis-Camera</AssignProfile>
      <AssignVLAN>1031</AssignVLAN>
    </Actions>
    <Priority>90</Priority>
    <Enabled>true</Enabled>
  </ProfilingPolicy>

  <ProfilingPolicy name="Cisco-IP-Phone-IPv6" description="Cisco IP Phone 8800 series with IPv6">
    <ParentPolicy>Cisco-IP-Phone</ParentPolicy>
    <Rules>
      <Rule>
        <RuleType>AND</RuleType>
        <Conditions>
          <Condition>
            <AttributeName>DHCPv6-Vendor-Class</AttributeName>
            <Operator>STARTS_WITH</Operator>
            <Value>ciscopnp</Value>
            <Description>Cisco Phone DHCPv6 vendor class</Description>
          </Condition>
          <Condition>
            <AttributeName>DHCP-Option(60)</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>Cisco Systems, Inc. IP Phone CP-88</Value>
            <Description>Cisco 8800 series phone</Description>
          </Condition>
          <Condition>
            <AttributeName>CDP-Platform</AttributeName>
            <Operator>CONTAINS</Operator>
            <Value>Cisco IP Phone</Value>
            <Description>CDP platform identifier</Description>
          </Condition>
        </Conditions>
      </Rule>
    </Rules>
    <Actions>
      <AssignSGT>15</AssignSGT>
      <AssignProfile>Cisco-IP-Phone-8800</AssignProfile>
      <AssignVLAN>1051</AssignVLAN>
      <VoiceVLAN>true</VoiceVLAN>
    </Actions>
    <Priority>110</Priority>
    <Enabled>true</Enabled>
  </ProfilingPolicy>

