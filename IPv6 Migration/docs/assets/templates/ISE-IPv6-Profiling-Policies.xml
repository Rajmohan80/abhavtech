  </NetworkDevices>

  <!-- DHCPv6 Attributes Dictionary -->
  <AttributeDictionary>
    <Attribute name="DHCPv6-Option(1)" type="binary" description="DHCPv6 Client Identifier (DUID)"/>
    <Attribute name="DHCPv6-Option(2)" type="binary" description="DHCPv6 Server Identifier"/>
    <Attribute name="DHCPv6-Option(3)" type="binary" description="Identity Association for Non-temporary Address"/>
    <Attribute name="DHCPv6-Option(15)" type="string" description="User Class"/>
    <Attribute name="DHCPv6-Option(16)" type="string" description="Vendor Class"/>
    <Attribute name="DHCPv6-Vendor-Class" type="string" description="Vendor-specific class identifier"/>
    <Attribute name="DHCPv6-DUID" type="string" description="DHCP Unique Identifier (persistent per device)"/>
  </AttributeDictionary>

  <!-- Authorization Policy Examples -->
  <AuthorizationPolicies>
    <Policy name="IPv6-Corporate-Access">
      <Conditions>
        <Condition>Network_Device_Type EQUALS Cisco-Switch</Condition>
        <Condition>Endpoint_Profile EQUALS Windows-Workstation-IPv6</Condition>
        <Condition>AD_Group CONTAINS Employees</Condition>
      </Conditions>
      <Results>
        <VLAN>1011</VLAN>
        <SGT>10</SGT>
        <ACL>CORPORATE-IN-v6-ACL</ACL>
        <VoiceDomain>Disabled</VoiceDomain>
      </Results>
    </Policy>

    <Policy name="IPv6-Guest-Access">
      <Conditions>
        <Condition>Network_Device_Type EQUALS Cisco-WLC</Condition>
        <Condition>SSID EQUALS Corp-Guest</Condition>
      </Conditions>
      <Results>
        <VLAN>1021</VLAN>
        <SGT>20</SGT>
        <ACL>GUEST-IN-v6-ACL</ACL>
        <RedirectURL>https://guest.abhavtech.com</RedirectURL>
      </Results>
    </Policy>

    <Policy name="IPv6-IoT-Access">
      <Conditions>
        <Condition>Endpoint_Profile EQUALS IoT-Camera-IPv6</Condition>
      </Conditions>
      <Results>
        <VLAN>1031</VLAN>
        <SGT>25</SGT>
        <ACL>IOT-IN-v6-ACL</ACL>
        <DHCPv6>Stateful</DHCPv6>
      </Results>
    </Policy>
  </AuthorizationPolicies>

  <!-- IPv6 ACL Templates -->
  <IPv6ACLs>
    <ACL name="CORPORATE-IN-v6-ACL">
      <Entries>
        <Entry sequence="10" action="permit" protocol="ipv6" source="any" destination="any"/>
        <Entry sequence="20" action="deny" protocol="icmpv6" source="any" destination="any" icmp-type="router-advertisement" comment="Block rogue RAs"/>
        <Entry sequence="30" action="permit" protocol="icmpv6" source="any" destination="any" comment="Allow other ICMPv6"/>
      </Entries>
    </ACL>

    <ACL name="GUEST-IN-v6-ACL">
      <Entries>
        <Entry sequence="10" action="deny" protocol="ipv6" source="any" destination="2001:db8:abc1:5000::/52" comment="Block server VLANs"/>
        <Entry sequence="20" action="permit" protocol="tcp" source="any" destination="any" port="80,443" comment="HTTP/HTTPS only"/>
        <Entry sequence="30" action="permit" protocol="udp" source="any" destination="any" port="53" comment="DNS"/>
        <Entry sequence="40" action="deny" protocol="ipv6" source="any" destination="any"/>
      </Entries>
    </ACL>

    <ACL name="IOT-IN-v6-ACL">
      <Entries>
        <Entry sequence="10" action="permit" protocol="tcp" source="any" destination="2001:db8:abc1:5001::/64" port="80,443" comment="To web servers"/>
        <Entry sequence="20" action="permit" protocol="udp" source="any" destination="any" port="53" comment="DNS"/>
        <Entry sequence="30" action="deny" protocol="ipv6" source="any" destination="any"/>
      </Entries>
    </ACL>
  </IPv6ACLs>
</ProfilingPolicyExport>
